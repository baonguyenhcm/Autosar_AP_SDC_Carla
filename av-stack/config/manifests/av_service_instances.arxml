<?xml version="1.0" encoding="UTF-8"?>
<!-- av-stack SERVICE INSTANCE MANIFEST (AUTOSAR AP R24-11) — SOME/IP deployment.
     Each Adaptive Application's provided/required service instances are bound to the
     SOME/IP binding (ARA_COM_EVENT_BINDING=vsomeip). Service/event/eventgroup IDs and
     SD config mirror the reference Adaptive-AUTOSAR manifests. -->
<AUTOSAR xmlns="http://autosar.org/schema/r4.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://autosar.org/schema/r4.0 autosar_00050.xsd">
  <AR-PACKAGES>
    <AR-PACKAGE>
      <SHORT-NAME>av</SHORT-NAME>
      <AR-PACKAGES>
        <AR-PACKAGE>
          <SHORT-NAME>ServiceInstances</SHORT-NAME>
          <ELEMENTS>

            <!-- ============ SensorService (id 0x1001) : gateway -> localization, perception ============ -->
            <PROVIDED-SOMEIP-SERVICE-INSTANCE>
              <SHORT-NAME>Gateway_SensorService_Provided</SHORT-NAME>
              <SERVICE-INTERFACE-DEPLOYMENT>
                <SERVICE-INTERFACE-ID>4097</SERVICE-INTERFACE-ID>
                <SERVICE-INTERFACE-VERSION><MAJOR-VERSION>1</MAJOR-VERSION><MINOR-VERSION>0</MINOR-VERSION></SERVICE-INTERFACE-VERSION>
              </SERVICE-INTERFACE-DEPLOYMENT>
              <PROVIDED-EVENT-GROUPS>
                <SOMEIP-PROVIDED-EVENT-GROUP>
                  <SHORT-NAME>SensorEvents</SHORT-NAME>
                  <EVENT-GROUP-ID>1</EVENT-GROUP-ID>
                  <EVENT-MULTICAST-UDP-PORT>30510</EVENT-MULTICAST-UDP-PORT>
                  <IPV-4-MULTICAST-IP-ADDRESS>239.0.1.1</IPV-4-MULTICAST-IP-ADDRESS>
                </SOMEIP-PROVIDED-EVENT-GROUP>
              </PROVIDED-EVENT-GROUPS>
              <SD-SERVER-CONFIG><INITIAL-OFFER-BEHAVIOR><INITIAL-DELAY-MIN-VALUE>20</INITIAL-DELAY-MIN-VALUE><INITIAL-DELAY-MAX-VALUE>200</INITIAL-DELAY-MAX-VALUE></INITIAL-OFFER-BEHAVIOR></SD-SERVER-CONFIG>
              <SERVICE-INSTANCE-ID>1</SERVICE-INSTANCE-ID>
            </PROVIDED-SOMEIP-SERVICE-INSTANCE>
            <REQUIRED-SOMEIP-SERVICE-INSTANCE>
              <SHORT-NAME>SensorService_Required</SHORT-NAME>   <!-- referenced by localization + perception -->
              <SERVICE-INTERFACE-DEPLOYMENT><SERVICE-INTERFACE-ID>4097</SERVICE-INTERFACE-ID><SERVICE-INTERFACE-VERSION><MAJOR-VERSION>1</MAJOR-VERSION><MINOR-VERSION>0</MINOR-VERSION></SERVICE-INTERFACE-VERSION></SERVICE-INTERFACE-DEPLOYMENT>
              <REQUIRED-EVENT-GROUPS><SOMEIP-REQUIRED-EVENT-GROUP><EVENT-GROUP-ID>1</EVENT-GROUP-ID></SOMEIP-REQUIRED-EVENT-GROUP></REQUIRED-EVENT-GROUPS>
              <SD-CLIENT-CONFIG><INITIAL-FIND-BEHAVIOR><INITIAL-DELAY-MIN-VALUE>20</INITIAL-DELAY-MIN-VALUE><INITIAL-DELAY-MAX-VALUE>200</INITIAL-DELAY-MAX-VALUE></INITIAL-FIND-BEHAVIOR></SD-CLIENT-CONFIG>
            </REQUIRED-SOMEIP-SERVICE-INSTANCE>

            <!-- ============ VehicleStateService (id 0x1002) : localization -> perception, planning, control ============ -->
            <PROVIDED-SOMEIP-SERVICE-INSTANCE>
              <SHORT-NAME>Localization_VehicleStateService_Provided</SHORT-NAME>
              <SERVICE-INTERFACE-DEPLOYMENT><SERVICE-INTERFACE-ID>4098</SERVICE-INTERFACE-ID><SERVICE-INTERFACE-VERSION><MAJOR-VERSION>1</MAJOR-VERSION><MINOR-VERSION>0</MINOR-VERSION></SERVICE-INTERFACE-VERSION></SERVICE-INTERFACE-DEPLOYMENT>
              <PROVIDED-EVENT-GROUPS><SOMEIP-PROVIDED-EVENT-GROUP><SHORT-NAME>StateEvents</SHORT-NAME><EVENT-GROUP-ID>1</EVENT-GROUP-ID><EVENT-MULTICAST-UDP-PORT>30511</EVENT-MULTICAST-UDP-PORT><IPV-4-MULTICAST-IP-ADDRESS>239.0.1.2</IPV-4-MULTICAST-IP-ADDRESS></SOMEIP-PROVIDED-EVENT-GROUP></PROVIDED-EVENT-GROUPS>
              <SD-SERVER-CONFIG><INITIAL-OFFER-BEHAVIOR><INITIAL-DELAY-MIN-VALUE>20</INITIAL-DELAY-MIN-VALUE><INITIAL-DELAY-MAX-VALUE>200</INITIAL-DELAY-MAX-VALUE></INITIAL-OFFER-BEHAVIOR></SD-SERVER-CONFIG>
              <SERVICE-INSTANCE-ID>1</SERVICE-INSTANCE-ID>
            </PROVIDED-SOMEIP-SERVICE-INSTANCE>
            <REQUIRED-SOMEIP-SERVICE-INSTANCE>
              <SHORT-NAME>VehicleStateService_Required</SHORT-NAME>
              <SERVICE-INTERFACE-DEPLOYMENT><SERVICE-INTERFACE-ID>4098</SERVICE-INTERFACE-ID><SERVICE-INTERFACE-VERSION><MAJOR-VERSION>1</MAJOR-VERSION><MINOR-VERSION>0</MINOR-VERSION></SERVICE-INTERFACE-VERSION></SERVICE-INTERFACE-DEPLOYMENT>
              <REQUIRED-EVENT-GROUPS><SOMEIP-REQUIRED-EVENT-GROUP><EVENT-GROUP-ID>1</EVENT-GROUP-ID></SOMEIP-REQUIRED-EVENT-GROUP></REQUIRED-EVENT-GROUPS>
              <SD-CLIENT-CONFIG><INITIAL-FIND-BEHAVIOR><INITIAL-DELAY-MIN-VALUE>20</INITIAL-DELAY-MIN-VALUE><INITIAL-DELAY-MAX-VALUE>200</INITIAL-DELAY-MAX-VALUE></INITIAL-FIND-BEHAVIOR></SD-CLIENT-CONFIG>
            </REQUIRED-SOMEIP-SERVICE-INSTANCE>

            <!-- ============ ObjectsService (id 0x1003) : perception -> planning ============ -->
            <PROVIDED-SOMEIP-SERVICE-INSTANCE>
              <SHORT-NAME>Perception_ObjectsService_Provided</SHORT-NAME>
              <SERVICE-INTERFACE-DEPLOYMENT><SERVICE-INTERFACE-ID>4099</SERVICE-INTERFACE-ID><SERVICE-INTERFACE-VERSION><MAJOR-VERSION>1</MAJOR-VERSION><MINOR-VERSION>0</MINOR-VERSION></SERVICE-INTERFACE-VERSION></SERVICE-INTERFACE-DEPLOYMENT>
              <PROVIDED-EVENT-GROUPS><SOMEIP-PROVIDED-EVENT-GROUP><SHORT-NAME>ObjectsEvents</SHORT-NAME><EVENT-GROUP-ID>1</EVENT-GROUP-ID><EVENT-MULTICAST-UDP-PORT>30512</EVENT-MULTICAST-UDP-PORT><IPV-4-MULTICAST-IP-ADDRESS>239.0.1.3</IPV-4-MULTICAST-IP-ADDRESS></SOMEIP-PROVIDED-EVENT-GROUP></PROVIDED-EVENT-GROUPS>
              <SD-SERVER-CONFIG><INITIAL-OFFER-BEHAVIOR><INITIAL-DELAY-MIN-VALUE>20</INITIAL-DELAY-MIN-VALUE><INITIAL-DELAY-MAX-VALUE>200</INITIAL-DELAY-MAX-VALUE></INITIAL-OFFER-BEHAVIOR></SD-SERVER-CONFIG>
              <SERVICE-INSTANCE-ID>1</SERVICE-INSTANCE-ID>
            </PROVIDED-SOMEIP-SERVICE-INSTANCE>
            <REQUIRED-SOMEIP-SERVICE-INSTANCE>
              <SHORT-NAME>ObjectsService_Required</SHORT-NAME>
              <SERVICE-INTERFACE-DEPLOYMENT><SERVICE-INTERFACE-ID>4099</SERVICE-INTERFACE-ID><SERVICE-INTERFACE-VERSION><MAJOR-VERSION>1</MAJOR-VERSION><MINOR-VERSION>0</MINOR-VERSION></SERVICE-INTERFACE-VERSION></SERVICE-INTERFACE-DEPLOYMENT>
              <REQUIRED-EVENT-GROUPS><SOMEIP-REQUIRED-EVENT-GROUP><EVENT-GROUP-ID>1</EVENT-GROUP-ID></SOMEIP-REQUIRED-EVENT-GROUP></REQUIRED-EVENT-GROUPS>
              <SD-CLIENT-CONFIG><INITIAL-FIND-BEHAVIOR><INITIAL-DELAY-MIN-VALUE>20</INITIAL-DELAY-MIN-VALUE><INITIAL-DELAY-MAX-VALUE>200</INITIAL-DELAY-MAX-VALUE></INITIAL-FIND-BEHAVIOR></SD-CLIENT-CONFIG>
            </REQUIRED-SOMEIP-SERVICE-INSTANCE>

            <!-- ============ TrajectoryService (id 0x1004) : planning -> control ============ -->
            <PROVIDED-SOMEIP-SERVICE-INSTANCE>
              <SHORT-NAME>Planning_TrajectoryService_Provided</SHORT-NAME>
              <SERVICE-INTERFACE-DEPLOYMENT><SERVICE-INTERFACE-ID>4100</SERVICE-INTERFACE-ID><SERVICE-INTERFACE-VERSION><MAJOR-VERSION>1</MAJOR-VERSION><MINOR-VERSION>0</MINOR-VERSION></SERVICE-INTERFACE-VERSION></SERVICE-INTERFACE-DEPLOYMENT>
              <PROVIDED-EVENT-GROUPS><SOMEIP-PROVIDED-EVENT-GROUP><SHORT-NAME>TrajectoryEvents</SHORT-NAME><EVENT-GROUP-ID>1</EVENT-GROUP-ID><EVENT-MULTICAST-UDP-PORT>30513</EVENT-MULTICAST-UDP-PORT><IPV-4-MULTICAST-IP-ADDRESS>239.0.1.4</IPV-4-MULTICAST-IP-ADDRESS></SOMEIP-PROVIDED-EVENT-GROUP></PROVIDED-EVENT-GROUPS>
              <SD-SERVER-CONFIG><INITIAL-OFFER-BEHAVIOR><INITIAL-DELAY-MIN-VALUE>20</INITIAL-DELAY-MIN-VALUE><INITIAL-DELAY-MAX-VALUE>200</INITIAL-DELAY-MAX-VALUE></INITIAL-OFFER-BEHAVIOR></SD-SERVER-CONFIG>
              <SERVICE-INSTANCE-ID>1</SERVICE-INSTANCE-ID>
            </PROVIDED-SOMEIP-SERVICE-INSTANCE>
            <REQUIRED-SOMEIP-SERVICE-INSTANCE>
              <SHORT-NAME>TrajectoryService_Required</SHORT-NAME>
              <SERVICE-INTERFACE-DEPLOYMENT><SERVICE-INTERFACE-ID>4100</SERVICE-INTERFACE-ID><SERVICE-INTERFACE-VERSION><MAJOR-VERSION>1</MAJOR-VERSION><MINOR-VERSION>0</MINOR-VERSION></SERVICE-INTERFACE-VERSION></SERVICE-INTERFACE-DEPLOYMENT>
              <REQUIRED-EVENT-GROUPS><SOMEIP-REQUIRED-EVENT-GROUP><EVENT-GROUP-ID>1</EVENT-GROUP-ID></SOMEIP-REQUIRED-EVENT-GROUP></REQUIRED-EVENT-GROUPS>
              <SD-CLIENT-CONFIG><INITIAL-FIND-BEHAVIOR><INITIAL-DELAY-MIN-VALUE>20</INITIAL-DELAY-MIN-VALUE><INITIAL-DELAY-MAX-VALUE>200</INITIAL-DELAY-MAX-VALUE></INITIAL-FIND-BEHAVIOR></SD-CLIENT-CONFIG>
            </REQUIRED-SOMEIP-SERVICE-INSTANCE>

            <!-- ============ ControlService (id 0x1005) : control -> gateway ============ -->
            <PROVIDED-SOMEIP-SERVICE-INSTANCE>
              <SHORT-NAME>Control_ControlService_Provided</SHORT-NAME>
              <SERVICE-INTERFACE-DEPLOYMENT><SERVICE-INTERFACE-ID>4101</SERVICE-INTERFACE-ID><SERVICE-INTERFACE-VERSION><MAJOR-VERSION>1</MAJOR-VERSION><MINOR-VERSION>0</MINOR-VERSION></SERVICE-INTERFACE-VERSION></SERVICE-INTERFACE-DEPLOYMENT>
              <PROVIDED-EVENT-GROUPS><SOMEIP-PROVIDED-EVENT-GROUP><SHORT-NAME>ControlEvents</SHORT-NAME><EVENT-GROUP-ID>1</EVENT-GROUP-ID><EVENT-MULTICAST-UDP-PORT>30514</EVENT-MULTICAST-UDP-PORT><IPV-4-MULTICAST-IP-ADDRESS>239.0.1.5</IPV-4-MULTICAST-IP-ADDRESS></SOMEIP-PROVIDED-EVENT-GROUP></PROVIDED-EVENT-GROUPS>
              <SD-SERVER-CONFIG><INITIAL-OFFER-BEHAVIOR><INITIAL-DELAY-MIN-VALUE>20</INITIAL-DELAY-MIN-VALUE><INITIAL-DELAY-MAX-VALUE>200</INITIAL-DELAY-MAX-VALUE></INITIAL-OFFER-BEHAVIOR></SD-SERVER-CONFIG>
              <SERVICE-INSTANCE-ID>1</SERVICE-INSTANCE-ID>
            </PROVIDED-SOMEIP-SERVICE-INSTANCE>
            <REQUIRED-SOMEIP-SERVICE-INSTANCE>
              <SHORT-NAME>ControlService_Required</SHORT-NAME>
              <SERVICE-INTERFACE-DEPLOYMENT><SERVICE-INTERFACE-ID>4101</SERVICE-INTERFACE-ID><SERVICE-INTERFACE-VERSION><MAJOR-VERSION>1</MAJOR-VERSION><MINOR-VERSION>0</MINOR-VERSION></SERVICE-INTERFACE-VERSION></SERVICE-INTERFACE-DEPLOYMENT>
              <REQUIRED-EVENT-GROUPS><SOMEIP-REQUIRED-EVENT-GROUP><EVENT-GROUP-ID>1</EVENT-GROUP-ID></SOMEIP-REQUIRED-EVENT-GROUP></REQUIRED-EVENT-GROUPS>
              <SD-CLIENT-CONFIG><INITIAL-FIND-BEHAVIOR><INITIAL-DELAY-MIN-VALUE>20</INITIAL-DELAY-MIN-VALUE><INITIAL-DELAY-MAX-VALUE>200</INITIAL-DELAY-MAX-VALUE></INITIAL-FIND-BEHAVIOR></SD-CLIENT-CONFIG>
            </REQUIRED-SOMEIP-SERVICE-INSTANCE>

            
          </ELEMENTS>
        </AR-PACKAGE>
      </AR-PACKAGES>
    </AR-PACKAGE>
  </AR-PACKAGES>
</AUTOSAR>
